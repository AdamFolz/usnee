# Dev mode: no real bot token needed, SQLite fallback, no Redis required
BOT_TOKEN=dev_token

# Database (SQLite for dev — zero-config, no Docker needed for DB)
DB_PASSWORD=dev
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# Redis (optional in dev)
REDIS_URL=redis://localhost:6379

# Mini App URL (for local dev)
WEBAPP_URL=http://localhost:5173

# Webhook URL (not used in dev)
WEBHOOK_URL=http://localhost:8000

# Encryption
ENCRYPTION_KEY=dev_encryption_key_123456789012345678901234567890

# Secret key for JWT
SECRET_KEY=dev_secret_key_123456789012345678901234567890

# Admin IDs (test user)
ADMIN_IDS=123456789

# CORS Origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080","http://localhost:3000","http://127.0.0.1:5173"]
