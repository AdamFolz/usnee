# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Database
DB_PASSWORD=your_secure_password
DATABASE_URL=postgresql+asyncpg://sekov:your_secure_password@postgres/sekov

# Redis
REDIS_URL=redis://redis:6379

# Mini App URL (для Telegram WebApp)
WEBAPP_URL=https://your-domain.com

# Encryption (сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))")
ENCRYPTION_KEY=your_encryption_key_here

# Secret key для JWT/сессий (сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your_secret_key_here

# Admin Telegram IDs (через запятую)
ADMIN_IDS=123456789

# CORS Origins (для Mini App)
CORS_ORIGINS=["https://*.telegram.org"]
